# holonbridge-mcp-remote environment
# Copy to .env and fill in values.  Never commit .env to version control.

# ── HolonBridge connection ────────────────────────────────────────────────────
# The public HTTPS URL of your HolonBridge REST API.
# For Ben's GGSC instance this will be his ngrok URL, NOT localhost.
HOLONBRIDGE_URL=https://ben-ggsc.ngrok.io

# Bearer token for HolonBridge REST calls.
# Must match BEARER_TOKEN in HolonBridge's own .env.
# Generate: openssl rand -hex 32
HB_BEARER_TOKEN=<holonbridge-bearer-token>

# ── This server's own auth ────────────────────────────────────────────────────
# A SEPARATE secret — clients (claude.ai) must supply this as their Bearer token
# when connecting to the /sse endpoint.
# Generate: openssl rand -hex 32
MCP_REMOTE_TOKEN=<generate-with-openssl-rand-hex-32>

# ── Server port ───────────────────────────────────────────────────────────────
MCP_PORT=3032

# ── Optional named profiles ───────────────────────────────────────────────────
# Clients can call set_endpoint("ggsc") to switch to a different HolonBridge.
# Pattern: PROFILE_<NAME>_URL and PROFILE_<NAME>_LABEL
#
# PROFILE_GGSC_URL=https://ggsc.holongraph.com
# PROFILE_GGSC_LABEL=UN GGSC production bridge
# PROFILE_LOCAL_URL=http://localhost:3031
# PROFILE_LOCAL_LABEL=Kurt local dev bridge

